{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "git fetch --all --prune --quiet 2>/dev/null || true",
            "async": true,
            "timeout": 60,
            "statusMessage": "Fetching latest refs from origin…"
          }
        ]
      }
    ]
  }
}
